# ──────────────────────────────────────────────
#  IP Camera System — Environment Configuration
#  Copy this file and adjust values for each server
# ──────────────────────────────────────────────

# Directory on the HOST where recordings are stored
# Use an absolute path to a large drive when available (e.g. /mnt/data/recordings)
RECORDINGS_DIR=/mnt/ipcam-storage/recordings

# Directory on the HOST for transient HLS live-stream segments
HLS_DIR=/mnt/ipcam-storage/hls

# Port nginx listens on (change if 80 is taken)
HTTP_PORT=80

# Timezone (used by recorder for file timestamps)
TIMEZONE=America/New_York

# Maximum storage in GB before circular-buffer deletion kicks in
# Set to 0 for unlimited (not recommended)
MAX_STORAGE_GB=3500

# ──────────────────────────────────────────────
#  ONVIF Scanner defaults (can also be set per-camera in cameras.yml)
# ──────────────────────────────────────────────
ONVIF_USERNAME=admin
ONVIF_PASSWORD=

# Subnet to scan for ONVIF cameras
CAMERA_SUBNET=192.168.100.0/24

# ──────────────────────────────────────────────
#  TigerSecu DVR credentials (used by the DVR proxy for auto-login)
# ──────────────────────────────────────────────
DVR_USERNAME=admin
DVR_PASSWORD=

# ──────────────────────────────────────────────
#  Excerpts — permanent clips never deleted by circular buffer
# ──────────────────────────────────────────────
# Directory on the HOST for permanent excerpts
EXCERPTS_DIR=/mnt/ipcam-storage/excerpts

# ──────────────────────────────────────────────
#  VOD — temporary HLS segments for recordings playback
#  Lives on /home (/dev/mapper/rhel-home) to avoid filling root or ipcam-storage
# ──────────────────────────────────────────────
VOD_DIR=/home/ipcam-vod
